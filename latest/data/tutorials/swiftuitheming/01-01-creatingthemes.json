nc createDefaultTheme() -> Theme {","        let colors: Theme.ColorMap","","        #if os(iOS) || os(visionOS)","        colors = [","            ...define iOS and visionOS color mappings,","        ]","        #elseif os(watchOS)","        colors = [","            ...define watchOS color mappings,","        ]","        #elseif os(macOS) || os(tvOS)","        colors = [","            ...define macOS and tvOS color mappings,","        ]","        #endif","","        return Theme(name: \"Default\", colors: colors)","    }","}"],"fileType":"swift"},"doc://dev.alexanderweiss.swiftui_theming/tutorials/SwiftUITheming/02-01-ChangeThemesAtRuntime#Create-a-view-to-change-the-theme":{"type":"section","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/02-01-ChangeThemesAtRuntime#Create-a-view-to-change-the-theme","kind":"section","role":"pseudoSymbol","abstract":[{"text":"Learn how to dynamically change themes at runtime.","type":"text"}],"title":"Create a view to change the theme","url":"\/tutorials\/swiftuitheming\/02-01-changethemesatruntime#Create-a-view-to-change-the-theme"},"01-01-01-code-0007.swift":{"syntax":"swift","fileType":"swift","identifier":"01-01-01-code-0007.swift","type":"file","fileName":"Themes.swift","content":["import Theming","","\/\/ MARK: - Available Themes","extension Theme {","    static let `default`: Theme = .createDefaultTheme()","}","","\/\/ MARK: - Previews","#Preview(\"Preview a theme\", traits: .withTheme(.default)) {","    Text(\"Hello, World!\")","        .foregroundStyle(.themeColor(for: .primaryLabel))","}","","#Preview(","    \"Preview a theme manager\",","    traits: .withThemeManager(ThemeManager(initialTheme: .default))",") {","    Text(\"Hello, World!\")","        .foregroundStyle(.themeColor(for: .primaryLabel))","}"],"highlights":[{"line":8},{"line":9},{"line":10},{"line":11},{"line":12},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18},{"line":19}]},"doc://dev.alexanderweiss.swiftui_the