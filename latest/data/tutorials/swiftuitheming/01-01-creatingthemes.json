"title":"Create your first theme","categoryPathComponent":"MeetSwiftUITheming","role":"project","category":"SwiftUI Theming"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-01-CreatingThemes"},"sections":[{"kind":"hero","title":"Create your first theme","estimatedTimeInMinutes":10,"content":[{"inlineContent":[{"type":"text","text":"Learn how to create and organize themes effectively in your application."}],"type":"paragraph"}],"chapter":"Essentials"},{"kind":"tasks","tasks":[{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Take the initial steps to make your app themeable."}]}]}],"title":"Create a theme","anchor":"Create-a-theme","stepsSection":[{"code":"01-01-01-code-0001.swift","caption":[],"runtimePreview":null,"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new SwiftUI View file named "},{"code":"Themes.swift","type":"codeVoice"},{"type":"text","text":". This file will serve as the central location for all the themes used in your app."}]}]},{"type":"step","caption":[],"media":null,"runtimePreview":null,"code":"01-01-01-code-0001.swift","content":[{"inlineContent":[{"text":"Each theme requires a name, a color mapping table, and optionally, a font mapping table. While the font mapping table is optional, the name and color mapping table are mandatory.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To gain better control over theme creation, use dedicated methods for each theme. This approach is similar to implementing a factory method."}]}],"runtimePreview":null,"media":null,"code":"01-01-01-code-0002.swift","caption":[],"type":"step"},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"With the foundational setup complete, proceed to create color mappings. Start by creating a new file named ","type":"text"},{"code":"ThemeColors.swift","type":"codeVoice"},{"type":"text","text":". This file will define all the color styles your app supports, typically derived from your app’s design guidelines. Each color style is uniquely identified by a name."}]}],"media":null,"code":"01-01-01-code-0003.swift","runtimePreview":null,"type":"step"},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Next, configure the mapping table to link color styles to their corresponding colors.","type":"text"}]}],"media":null,"code":"01-01-01-code-0004.swift","runtimePreview":null,"type":"step"},{"code":"01-01-01-code-0005.swift","runtimePreview":null,"content":[{"inlineContent":[{"text":"If your app supports multiple platforms, you may need to create different mappings, as not all color variants are available across every platform. This also allows you to define distinct color sets tailored to each platform.","type":"text"}],"type":"paragraph"}],"caption":[],"type":"step","media":null},{"caption":[],"media":null,"runtimePreview":null,"code":"01-01-01-code-0006.swift","content":[{"type":"paragraph","inlineContent":[{"text":"Finally, create a theme instance, give it a meaningful name, and assign the color mapping you have defined.","type":"text"}]}],"type":"step"},{"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to test your themes with SwiftUI previews, you can use the built-in preview traits."}]}],"code":"01-01-01-code-0007.swift","runtimePreview":null,"media":null}]}]},{"title":"Enable Theming","abstract":[{"type":"text","text":"Learn how to enable theming in your SwiftUI application."}],"kind":"callToAction","featuredEyebrow":"Tutorial","action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-02-EnableTheming","isActive":true,"overridingTi