 [","                ...,","            ]","            #elseif os(macOS)","            let fonts: Theme.FontMap = [","                ...,","            ]","            #elseif os(watchOS)","            let fonts: Theme.FontMap = [","                ...,","            ]","            #endif","","        return Theme(name: colors, colors: fonts)","    }","}"],"identifier":"01-03-02-code-0005.swift","syntax":"swift","fileName":"Themes.swift","fileType":"swift","type":"file"},"01-03-02-code-0007.swift":{"syntax":"swift","fileName":"ContentView.swift","identifier":"01-03-02-code-0007.swift","type":"file","highlights":[{"line":9},{"line":10}],"content":["import SwiftUI","import Theming","","struct ContentView: View {","    \/\/ MARK: - Body","    var body: some View {","        Text(\"Hello World\")","            .themeFont(.largeTitle)","            .fontWeight(.bold)","            .foregroundStyle(Color.themeColor(for: .primaryLabel))","    }","}"],"fileType":"swift"},"01-03-02-code-0006.swift":{"highlights":[],"content":["import SwiftUI","import Theming","","struct ContentView: View {","    \/\/ MARK: - Body","    var body: some View {","        Text(\"Hello World\")","            .themeFont(.largeTitle)","    }","}"],"identifier":"01-03-02-code-0006.swift","syntax":"swift","fileName":"ContentView.swift","fileType":"swift","type":"file"},"01-03-02-code-0002.swift":{"syntax":"swift","fileName":"Themes.swift","identifier":"01-03-02-code-0002.swift","type":"file","highlights":[],"content":["import Theming","","\/\/ MARK: - Available Themes","extension Theme {","    static let `default`: Theme = .createDefaultTheme()","}","","\/\/ MARK: - Theme creation","extension Theme {","    private static func createDefaultTheme() -> Theme {","        \/\/ Color mapping","        let colors: Theme.ColorMap = \/\/ your color setup","    }","}"],"fileType":"swift"},"01-03-01-code-0001.plist":{"content":["<?xml version=\"1.0\" encoding=\"UTF-8\"?>","<!DOCTYPE plist PUBLIC \"-\/\/Apple\