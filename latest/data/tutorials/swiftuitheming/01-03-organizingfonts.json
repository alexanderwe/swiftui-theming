{"variants":[{"paths":["\/tutorials\/swiftuitheming\/01-03-organizingfonts"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-03-OrganizingFonts","interfaceLanguage":"swift"},"kind":"project","hierarchy":{"modules":[{"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming\/Essentials","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-01-CreatingThemes#Create-a-theme"}],"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-01-CreatingThemes"},{"sections":[{"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-02-EnableTheming#Add-the-Theme-Manager","kind":"task"}],"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-02-EnableTheming"},{"sections":[{"kind":"task","reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-03-OrganizingFonts#Add-Fonts-to-Your-Application"},{"kind":"task","reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-03-OrganizingFonts#Accessing-Your-Custom-Fonts-in-a-Theme"}],"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-03-OrganizingFonts"}]},{"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming\/Advanced","projects":[{"sections":[{"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/02-01-ChangeThemesAtRuntime#Create-a-view-to-change-the-theme","kind":"task"}],"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/02-01-ChangeThemesAtRuntime"}]}],"reference":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming","paths":[["doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming","doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming\/$volume","doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming\/Essentials"]]},"metadata":{"role":"project","title":"Organize Fonts","category":"SwiftUI Theming","categoryPathComponent":"MeetSwiftUITheming"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[{"kind":"hero","title":"Organize Fonts","content":[{"inlineContent":[{"type":"text","text":"Learn how to organize fonts for use in a theme."}],"type":"paragraph"}],"chapter":"Essentials","estimatedTimeInMinutes":15},{"kind":"tasks","tasks":[{"stepsSection":[{"code":null,"type":"step","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To use custom fonts in your application, add the font files to your app’s resources. It’s best to keep resources organized and separate from source code files. If you haven’t done so already, create a folder named "},{"code":"Resources\/Fonts","type":"codeVoice"},{"type":"text","text":" and place all your font files in it."}]}],"media":"01-03-01-image-0001.png","caption":[]},{"code":"01-03-01-code-0001.plist","caption":[{"content":[{"inlineContent":[{"text":"Ensure that you include the file extensions for each font listed under the ","type":"text"},{"code":"UIAppFonts","type":"codeVoice"},{"text":" key.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Attention","style":"note"}],"runtimePreview":null,"media":null,"type":"step","content":[{"inlineContent":[{"text":"Next, inform the application that it will use custom fonts. For ","type":"text"},{"code":"macOS","type":"codeVoice"},{"text":" applications, set the ","type":"text"},{"code":"ATSApplicationFontsPath","type":"codeVoice"},{"text":" key to ","type":"text"},{"code":".","type":"codeVoice"},{"type":"text","text":" in your "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" file. For other platforms, declare all font files under the "},{"code":"UIAppFonts","type":"codeVoice"},{"text":" key.","type":"text"}],"type":"paragraph"}]}],"title":"Add Fonts to Your Application","contentSection":[{"kind":"fullWidth","content":[{"inlineContent":[{"type":"text","text":"By default, SwiftUI Theming uses Apple’s system fonts for all themes. This approach is recommended because Apple’s fonts are highly optimized, offer best-in-class features, and are fully compatible with SwiftUI’s font modifiers. However, certain situations or product requirements might necessitate the use of custom fonts. In this tutorial, you’ll learn how to enable custom fonts with SwiftUI Theming by registering them in the traditional way."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"There is also a way to register fonts programmatically when distributed via a framework. This method is not covered in this tutorial yet."}],"type":"paragraph"}],"name":"Note","style":"note","type":"aside"}]}],"anchor":"Add-Fonts-to-Your-Application"},{"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"After making the font files accessible to your app, the next step is to add them to a theme."}],"type":"paragraph"}],"kind":"fullWidth"}],"stepsSection":[{"code":"01-03-02-code-0002.swift","runtimePreview":null,"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Start by using your existing code for creating themes."}],"type":"paragraph"}],"caption":[]},{"type":"step","code":"01-03-02-code-0003.swift","content":[{"type":"paragraph","inlineContent":[{"text":"To incorporate custom fonts into a theme, create a mapping table. This table maps the ","type":"text"},{"type":"codeVoice","code":"Font.TextStyles"},{"text":" you want to use in your app to the custom fonts. You have flexibility in how you implement this mapping, as long as each text style maps to a ","type":"text"},{"type":"codeVoice","code":"Font"},{"text":" instance.","type":"text"}]}],"media":null,"runtimePreview":null,"caption":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/font\/custom(_:size:relativeto:)","type":"reference"},{"text":" initializer of SwiftUI’s ","type":"text"},{"code":"Font","type":"codeVoice"},{"text":" type to support dynamic type and ensure accessibility.","type":"text"}]}],"type":"aside","name":"Tip","style":"tip"}]},{"type":"step","code":"01-03-02-code-0004.swift","content":[{"type":"paragraph","inlineContent":[{"text":"If needed, you can define different mappings for each platform. This is especially useful when using platform-specific fonts or sizes.","type":"text"}]}],"media":null,"runtimePreview":null,"caption":[]},{"type":"step","code":"01-03-02-code-0005.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the font mapping is complete, add it to the "},{"code":"Theme","type":"codeVoice"},{"type":"text","text":" initializer, replacing the default Apple font mapping with your custom font mapping."}]}],"media":null,"runtimePreview":null,"caption":[]},{"code":"01-03-02-code-0006.swift","content":[{"inlineContent":[{"type":"text","text":"The final step is to access the custom font in your views."}],"type":"paragraph"}],"media":null,"runtimePreview":"01-03-02-image-0001.png","type":"step","caption":[]},{"code":"01-03-02-code-0007.swift","content":[{"type":"paragraph","inlineContent":[{"text":"If your font supports different weights, you can use SwiftUI’s standard font modifiers to access these variants. Additionally, you can change the text color to one of the colors defined in your theme.","type":"text"}]}],"media":null,"runtimePreview":"01-03-02-image-0002.png","type":"step","caption":[]}],"anchor":"Accessing-Your-Custom-Fonts-in-a-Theme","title":"Accessing Your Custom Fonts in a Theme"}]},{"featuredEyebrow":"Tutorial","kind":"callToAction","title":"Change themes at runtime","abstract":[{"text":"Learn how to dynamically change themes at runtime.","type":"text"}],"action":{"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/02-01-ChangeThemesAtRuntime","isActive":true,"overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference"}}],"references":{"01-03-02-code-0003.swift":{"content":["import Theming","","\/\/ MARK: - Available Themes","extension Theme {","    static let `default`: Theme = .createDefaultTheme()","}","","\/\/ MARK: - Theme creation","extension Theme {","    private static func createDefaultTheme() -> Theme {","        \/\/ Color mapping","        let colors: Theme.ColorMap = \/\/ your color setup","","            \/\/ Font mapping","            let fonts: Theme.FontMap = [","                .largeTitle: Font.custom(\"CustomFont-Regular\", size: 34, relativeTo: .largeTitle),","                .title: Font.custom(\"CustomFont-Regular\", size: 28, relativeTo: .title),","                .title2: Font.custom(\"CustomFont-Regular\", size: 22, relativeTo: .title2),","                .title3: Font.custom(\"CustomFont-Regular\", size: 20, relativeTo: .title3),","                .headline: Font.custom(\"CustomFont-Regular\", size: 17, relativeTo: .headline),","                .body: Font.custom(\"CustomFont-Regular\", size: 17, relativeTo: .body),","                .callout: Font.custom(\"CustomFont-Regular\", size: 16, relativeTo: .callout),","                .subheadline: Font.custom(\"CustomFont-Regular\", size: 15, relativeTo: .subheadline),","                .footnote: Font.custom(\"CustomFont-Regular\", size: 13, relativeTo: .footnote),","                .caption: Font.custom(\"CustomFont-Regular\", size: 12, relativeTo: .caption),","                .caption2: Font.custom(\"CustomFont-Regular\", size: 11, relativeTo: .caption2),","            ]","    }","}"],"fileType":"swift","syntax":"swift","fileName":"Themes.swift","type":"file","highlights":[{"line":13},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27}],"identifier":"01-03-02-code-0003.swift"},"01-03-02-image-0002.png":{"alt":"An iOS application displaying bold text with a custom font and a theme-defined primary label color. The text color is blue.","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/dev.alexanderweiss.swiftui_theming\/01-03-02-image-0002.png"}],"identifier":"01-03-02-image-0002.png"},"doc://dev.alexanderweiss.swiftui_theming/tutorials/MeetSwiftUITheming/Essentials":{"type":"topic","abstract":[],"title":"Essentials","role":"article","kind":"article","url":"\/tutorials\/meetswiftuitheming\/essentials","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming\/Essentials"},"https://developer.apple.com/documentation/swiftui/font/custom(_:size:relativeto:)":{"identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/font\/custom(_:size:relativeto:)","url":"https:\/\/developer.apple.com\/documentation\/swiftui\/font\/custom(_:size:relativeto:)","type":"link","title":"custom(_:size:relativeTo:)","titleInlineContent":[{"type":"text","text":"custom(_:size:relativeTo:)"}]},"doc://dev.alexanderweiss.swiftui_theming/tutorials/SwiftUITheming/01-03-OrganizingFonts":{"role":"project","title":"Organize Fonts","abstract":[{"type":"text","text":"Learn how to organize fonts for use in a theme."}],"kind":"project","estimatedTime":"15min","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-03-OrganizingFonts","url":"\/tutorials\/swiftuitheming\/01-03-organizingfonts"},"doc://dev.alexanderweiss.swiftui_theming/tutorials/SwiftUITheming/02-01-ChangeThemesAtRuntime":{"role":"project","title":"Change themes at runtime","abstract":[{"text":"Learn how to dynamically change themes at runtime.","type":"text"}],"kind":"project","estimatedTime":"15min","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/Sw