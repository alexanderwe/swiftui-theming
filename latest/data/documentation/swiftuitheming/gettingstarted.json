{"metadata":{"title":"Getting Started","roleHeading":"Article","role":"article"},"sections":[],"kind":"article","identifier":{"url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/SwiftUITheming\/GettingStarted","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/swiftuitheming\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"text":"Adding swiftui-theming as a dependency","level":2,"anchor":"Adding-swiftui-theming-as-a-dependency","type":"heading"},{"syntax":"swift","type":"codeListing","code":["let package = Package(","  dependencies: [","    .package(","      url: \"https:\/\/github.com\/alexanderwe\/swiftui-theming\",","      from: \"0.1.1\"","    ),","  ],","  targets: [","    .target(","      name: \"<target-name>\",","      dependencies: [","        .product(","          name: \"Theming\",","          package: \"swiftui-theming\"","        )","      ]","    )","  ]",")"]},{"type":"heading","anchor":"Create-your-first-theme","level":2,"text":"Create your first theme"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Be sure to checkout "},{"isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming","type":"reference"},{"type":"text","text":" for an interactive tutorial."}],"type":"paragraph"}],"style":"note"},{"anchor":"Step-1-Define-Color-Styles","level":3,"text":"Step 1: Define Color Styles","type":"heading"},{"inlineContent":[{"type":"text","text":"Before creating a new theme, define the color styles available in your app:"}],"type":"paragraph"},{"syntax":"swift","code":["import Theming","","extension ThemeColorStyle {","    \/\/\/ A style for primary labels","    static let primaryLabel: Self = Self(name: \"primaryLabel\")","    \/\/ Define additional styles as needed","}"],"type":"codeListing"},{"anchor":"Step-2-Create-a-Theme","level":3,"text":"Step 2: Create a Theme","type":"heading"},{"inlineContent":[{"type":"text","text":"With color styles defined, implement a method to create a theme. Each theme requires to at least have a name and a color mapping. Depending on your needs you may need different mappings on different platforms since not all color "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeColor","isActive":true},{"type":"text","text":" variants are available on all platforms."}],"type":"paragraph"},{"syntax":"swift","code":["import Theming","\/\/ MARK: - Available Themes","extension Theme {","    static let `default`: Theme = .createDefaultTheme()","}","","\/\/ MARK: - Theme Creation","extension Theme {","    private static func createDefaultTheme() -> Theme {","        let colors: Theme.ColorMap = [","            .primaryLabel: ThemeColor(lightColor: .primary, darkColor: .primary)","        ]","        return Theme(name: \"Default\", colors: colors)","    }","}"],"type":"codeListing"},{"anchor":"Make-App-themeable","level":2,"type":"heading","text":"Make App themeable"},{"inlineContent":[{"type":"text","text":"To enable theming in your app, inject a "},{"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeManager","isActive":true,"type":"reference"},{"text":" instance into your app’s scenes.","type":"text"}],"type":"paragraph"},{"anchor":"Step-1-Initialize-ThemeManager","level":3,"type":"heading","text":"Step 1: Initialize `ThemeManager`"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Declare a "},{"type":"codeVoice","code":"@State"},{"type":"text","text":" property to hold the "},{"code":"ThemeManager","type":"codeVoice"},{"type":"text","text":" in your app definition:"}]},{"syntax":"swift","type":"codeListing","code":["import SwiftUI","import Theming","","@main","struct MyApp: App {","    @State var myThemeManager: ThemeManager = ThemeManager(initialTheme: .default)","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","        .withThemeManager(themeManager: myThemeManager)","    }","}"]},{"text":"Step 2: Access Theme Colors in Views","level":3,"anchor":"Step-2-Access-Theme-Colors-in-Views","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"code":".themeColor","type":"codeVoice"},{"type":"text","text":" method to apply theme colors in your SwiftUI views:"}]},{"syntax":"swift","type":"codeListing","code":["struct ContentView: View {","    var body: some View {","        Text(\"Hello World\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","    }","}"]},{"text":"SwiftUI previews","level":2,"anchor":"SwiftUI-previews","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to test your themes in SwiftUI previews, you can either inject a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeManager"},{"type":"text","text":" or a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme"}]},{"syntax":"swift","type":"codeListing","code":["#Preview(","    traits: .withThemeManager(ThemeManager(initialTheme: .createDefaultTheme()))",") {","    Text(\"Hello, world!\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","}"]},{"syntax":"swift","type":"codeListing","code":["#Preview(","    traits: .withTheme(.createDefaultTheme())",") {","    Text(\"Hello, world!\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","}"]}],"kind":"content"}],"abstract":[{"text":"Learn how to integrate SwiftUI Theming into your project.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Overview"]]},"references":{"doc://dev.alexanderweiss.swiftui_theming/documentation/Overview":{"abstract":[],"kind":"article","title":"SwiftUI Theming Docume