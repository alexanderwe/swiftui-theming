{"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Adding-swiftui-theming-as-a-dependency","text":"Adding swiftui-theming as a dependency","type":"heading"},{"code":["let package = Package(","  dependencies: [","    .package(","      url: \"https:\/\/github.com\/alexanderwe\/swiftui-theming\",","      from: \"0.1.1\"","    ),","  ],","  targets: [","    .target(","      name: \"<target-name>\",","      dependencies: [","        .product(","          name: \"Theming\",","          package: \"swiftui-theming\"","        )","      ]","    )","  ]",")"],"syntax":"swift","type":"codeListing"},{"type":"heading","text":"Create your first theme","level":2,"anchor":"Create-your-first-theme"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Be sure to checkout "},{"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming","type":"reference","isActive":true},{"type":"text","text":" for an interactive tutorial."}]}],"type":"aside","style":"note","name":"Note"},{"type":"heading","text":"Step 1: Define Color Styles","anchor":"Step-1-Define-Color-Styles","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before creating a new theme, define the color styles available in your app:"}]},{"code":["import Theming","","extension ThemeColorStyle {","    \/\/\/ A style for primary labels","    static let primaryLabel: Self = Self(name: \"primaryLabel\")","    \/\/ Define additional styles as needed","}"],"type":"codeListing","syntax":"swift"},{"text":"Step 2: Create a Theme","anchor":"Step-2-Create-a-Theme","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"With color styles defined, implement a method to create a theme. Each theme requires to at least have a name and a color mapping. Depending on your needs you may need different mappings on different platforms since not all color "},{"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeColor","type":"reference","isActive":true},{"text":" variants are available on all platforms.","type":"text"}],"type":"paragraph"},{"code":["import Theming","\/\/ MARK: - Available Themes","extension Theme {","    static let `default`: Theme = .createDefaultTheme()","}","","\/\/ MARK: - Theme Creation","extension Theme {","    private static func createDefaultTheme() -> Theme {","        let colors: Theme.ColorMap = [","            .primaryLabel: ThemeColor(lightColor: .primary, darkColor: .primary)","        ]","        return Theme(name: \"Default\", colors: colors)","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Make App themeable","type":"heading","level":2,"anchor":"Make-App-themeable"},{"type":"paragraph","inlineContent":[{"text":"To enable theming in your app, inject a ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeManager","isActive":true,"type":"reference"},{"text":" instance into your app’s scenes.","type":"text"}]},{"anchor":"Step-1-Initialize-ThemeManager","text":"Step 1: Initialize `ThemeManager`","type":"heading","level":3},{"inlineContent":[{"text":"Declare a ","type":"text"},{"type":"codeVoice","code":"@State"},{"text":" property to hold the ","type":"text"},{"type":"codeVoice","code":"ThemeManager"},{"text":" in your app definition:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import SwiftUI","import Theming","","@main","struct MyApp: App {","    @State var myThemeManager: ThemeManager = ThemeManager(initialTheme: .default)","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","        .withThemeManager(themeManager: myThemeManager)","    }","}"],"type":"codeListing"},{"type":"heading","text":"Step 2: Access Theme Colors in Views","level":3,"anchor":"Step-2-Access-Theme-Colors-in-Views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":".themeColor"},{"type":"text","text":" method to apply theme colors in your SwiftUI views:"}]},{"type":"codeListing","code":["struct ContentView: View {","    var body: some View {","        Text(\"Hello World\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","    }","}"],"syntax":"swift"},{"text":"SwiftUI previews","anchor":"SwiftUI-previews","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"In order to test your themes in SwiftUI previews, you can either inject a ","type":"text"},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeManager","isActive":true},{"text":" or a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme"}]},{"code":["#Preview(","    traits: .withThemeManager(ThemeManager(initialTheme: .createDefaultTheme()))",") {","    Text(\"Hello, world!\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","}"],"type":"codeListing","syntax":"swift"},{"code":["#Preview(","    traits: .withTheme(.createDefaultTheme())",") {","    Text(\"Hello, world!\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","}"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftuitheming\/gettingstarted"]}],"identifier":{"url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/SwiftUITheming\/GettingStarted","interfaceLanguage":"swift"},"kind":"article","abstract":[{"type":"text","text":"Learn how to integrate SwiftUI Theming into your project."}],"hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Overview"]]},"metadata":{"role":"article","roleHeading":"Article","title":"Getting Started"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"references":{"doc://dev.alexanderweiss.swiftui_theming/tutorials/MeetSwiftUITheming":{"title":"Meet SwiftUI Theming","type":"topic","identifie