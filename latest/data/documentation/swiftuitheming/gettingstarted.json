":"text"}],"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Theme"}],"kind":"symbol","navigatorTitle":[{"text":"Theme","kind":"identifier"}]}}}