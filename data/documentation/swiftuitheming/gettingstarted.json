{"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Adding swiftui-theming as a dependency","anchor":"Adding-swiftui-theming-as-a-dependency"},{"syntax":"swift","type":"codeListing","code":["let package = Package(","  dependencies: [","    .package(","      url: \"https:\/\/github.com\/alexanderwe\/swiftui-theming\",","      from: \"0.1.1\"","    ),","  ],","  targets: [","    .target(","      name: \"<target-name>\",","      dependencies: [","        .product(","          name: \"Theming\",","          package: \"swiftui-theming\"","        )","      ]","    )","  ]",")"]},{"anchor":"Create-your-first-theme","level":2,"type":"heading","text":"Create your first theme"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Be sure to checkout "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming","isActive":true},{"type":"text","text":" for an interactive tutorial."}]}],"name":"Note","type":"aside"},{"anchor":"Step-1-Define-Color-Styles","level":3,"type":"heading","text":"Step 1: Define Color Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before creating a new theme, define the color styles available in your app:"}]},{"code":["import Theming","","extension ThemeColorStyle {","    \/\/\/ A style for primary labels","    static let primaryLabel: Self = Self(name: \"primaryLabel\")","    \/\/ Define additional styles as needed","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Step 2: Create a Theme","anchor":"Step-2-Create-a-Theme","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"With color styles defined, implement a method to create a theme. Each theme requires to at least have a name and a color mapping. Depending on your needs you may need different mappings on different platforms since not all color "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeColor","isActive":true},{"type":"text","text":" variants are available on all platforms."}]},{"code":["import Theming","\/\/ MARK: - Available Themes","extension Theme {","    static let `default`: Theme = .createDefaultTheme()","}","","\/\/ MARK: - Theme Creation","extension Theme {","    private static func createDefaultTheme() -> Theme {","        let colors: Theme.ColorMap = [","            .primaryLabel: ThemeColor(lightColor: .primary, darkColor: .primary)","        ]","        return Theme(name: \"Default\", colors: colors)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Make App themeable","anchor":"Make-App-themeable","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To enable theming in your app, inject a "},{"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeManager","isActive":true,"type":"reference"},{"text":" instance into your app’s scenes.","type":"text"}]},{"type":"heading","text":"Step 1: Initialize `ThemeManager`","anchor":"Step-1-Initialize-ThemeManager","level":3},{"type":"paragraph","inlineContent":[{"text":"Declare a ","type":"text"},{"code":"@State","type":"codeVoice"},{"text":" property to hold the ","type":"text"},{"code":"ThemeManager","type":"codeVoice"},{"text":" in your app definition:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import Theming","","@main","struct MyApp: App {","    @State var myThemeManager: ThemeManager = ThemeManager(initialTheme: .default)","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","        .withThemeManager(themeManager: myThemeManager)","    }","}"]},{"level":3,"type":"heading","text":"Step 2: Access Theme Colors in Views","anchor":"Step-2-Access-Theme-Colors-in-Views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":".themeColor"},{"type":"text","text":" method to apply theme colors in your SwiftUI views:"}]},{"type":"codeListing","syntax":"swift","code":["struct ContentView: View {","    var body: some View {","        Text(\"Hello World\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","    }","}"]},{"anchor":"SwiftUI-previews","level":2,"type":"heading","text":"SwiftUI previews"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to test your themes in SwiftUI previews, you can either inject a "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeManager","isActive":true},{"type":"text","text":" or a "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme","isActive":true}]},{"code":["#Preview(","    traits: .withThemeManager(ThemeManager(initialTheme: .createDefaultTheme()))",") {","    Text(\"Hello, world!\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","}"],"type":"codeListing","syntax":"swift"},{"code":["#Preview(","    traits: .withTheme(.createDefaultTheme())",") {","    Text(\"Hello, world!\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","}"],"type":"codeListing","syntax":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Overview"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"Getting Started","roleHeading":"Article","role":"article"},"identifier":{"url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/SwiftUITheming\/GettingStarted","interfaceLanguage":"swift"},"sections":[],"variants":[{"paths":["\/documentation\/swiftuitheming\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","abstract":[{"type":"text","text":"Learn how to integrate SwiftUI Theming into your project."}],"references":{"doc://dev.alexanderweiss.swiftui_theming/documentation/Theming/ThemeColor":{"url":"\/documentation\/theming\/themecolor","navigatorTitle":[{"text":"ThemeColor","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeColor","abstract":[{"type":"text","text":"A color representing all possible variations where this color is used."}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThemeColor","kind":"identifier"}],"kind":"symbol","title":"ThemeColor"},"doc://dev.alexanderweiss.swiftui_theming/documentation/Theming/ThemeManager":{"title":"ThemeManager","abstract":[{"type":"text","text":"Manages the currently available theme in the app."}],"url":"\/documentation\/theming\/thememanager","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThemeManager","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"ThemeManager","kind":"identifier"}],"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeManager","kind":"symbol","type":"topic"},"doc://dev.alexanderweiss.swiftui_theming/tutorials/MeetSwiftUITheming":{"type":"topic","title":"Meet SwiftUI Theming","role":"overview","url":"\/tutorials\/meetswiftuitheming","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming","abstract":[{"type":"text","text":"SwiftUI Theming is a library that enables seamless theming in SwiftUI across all Apple platforms, including iOS, macOS, tvOS, watchOS, and visionOS."}],"kind":"overview"},"doc://dev.alexanderweiss.swiftui_theming/documentation/Theming/Theme":{"type":"topic","title":"Theme","role":"symbol","abstract":[{"text":"Base type for the theming system describing a single theme.","type":"text"}],"url":"\/documentation\/theming\/theme","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme","navigatorTitle":[{"text":"Theme","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Theme","kind":"identifier"}]},"doc://dev.alexanderweiss.swiftui_theming/documentation/Overview":{"type":"topic","title":"SwiftUI Theming Documentation","role":"collection","abstract":[],"url":"\/documentation\/overview","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Overview","kind":"article"}}}