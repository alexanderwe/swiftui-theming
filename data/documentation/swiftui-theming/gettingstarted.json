{"identifier":{"url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/swiftui-theming\/GettingStarted","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Adding swiftui-theming as a dependency","anchor":"Adding-swiftui-theming-as-a-dependency"},{"syntax":"swift","code":["let package = Package(","  dependencies: [","    .package(","      url: \"https:\/\/github.com\/alexanderwe\/swiftui-theming\",","      from: \"0.1.0\"","    ),","  ],","  targets: [","    .target(","      name: \"<target-name>\",","      dependencies: [","        .product(","          name: \"Theming\",","          package: \"swiftui-theming\"","        )","      ]","    )","  ]",")"],"type":"codeListing"},{"text":"Create your first theme","level":2,"anchor":"Create-your-first-theme","type":"heading"},{"type":"aside","content":[{"inlineContent":[{"text":"Be sure to checkout ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming","type":"reference","isActive":true},{"text":" for an interactive tutorial.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note"},{"text":"Step 1: Define Color Styles","anchor":"Step-1-Define-Color-Styles","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before creating a new theme, define the color styles available in your app:"}]},{"type":"codeListing","code":["import Theming","","extension ThemeColorStyle {","    \/\/\/ A style for primary labels","    static let primaryLabel: Self = Self(name: \"primaryLabel\")","    \/\/ Define additional styles as needed","}"],"syntax":"swift"},{"anchor":"Step-2-Create-a-Theme","text":"Step 2: Create a Theme","level":3,"type":"heading"},{"inlineContent":[{"text":"With color styles defined, implement a method to create a theme. Each theme requires to at least have a name and a color mapping. Depending on your needs you may need different mappings on different platforms since not all color ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeColor","isActive":true,"type":"reference"},{"type":"text","text":" variants are available on all platforms."}],"type":"paragraph"},{"code":["import Theming","\/\/ MARK: - Available Themes","extension Theme {","    static let `default`: Theme = .createDefaultTheme()","}","","\/\/ MARK: - Theme Creation","extension Theme {","    private static func createDefaultTheme() -> Theme {","        let colors: Theme.ColorMap = [","            .primaryLabel: ThemeColor(lightColor: .primary, darkColor: .primary)","        ]","        return Theme(name: \"Default\", colors: colors)","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Make-App-themeable","level":2,"type":"heading","text":"Make App themeable"},{"inlineContent":[{"type":"text","text":"To enable theming in your app, inject a "},{"code":"ThemeManager","type":"codeVoice"},{"text":" instance into your app’s scenes.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Step-1-Initialize-ThemeManager","level":3,"text":"Step 1: Initialize `ThemeManager`"},{"inlineContent":[{"type":"text","text":"Declare a "},{"type":"codeVoice","code":"@State"},{"type":"text","text":" property to hold the "},{"type":"codeVoice","code":"ThemeManager"},{"type":"text","text":" in your app definition:"}],"type":"paragraph"},{"code":["import SwiftUI","import Theming","","@main","struct MyApp: App {","    @State var myThemeManager: ThemeManager = ThemeManager(initialTheme: .default)","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","        .withThemeManager(themeManager: myThemeManager)","    }","}"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Step-2-Access-Theme-Colors-in-Views","type":"heading","text":"Step 2: Access Theme Colors in Views"},{"inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":".themeColor"},{"text":" method to apply theme colors in your SwiftUI views:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct ContentView: View {","    var body: some View {","        Text(\"Hello World\")","            .foregroundStyle(.themeColor(for: .primaryLabel))","    }","}"],"type":"codeListing"}],"kind":"content"}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Learn how to integrate SwiftUI Theming into your project.","type":"text"}],"metadata":{"title":"Getting Started","role":"article","roleHeading":"Article"},"kind":"article","hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Overview"]]},"references":{"doc://dev.alexanderweiss.swiftui_theming/documentation/Theming/ThemeColor":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ThemeColor"}],"kind":"symbol","title":"ThemeColor","navigatorTitle":[{"text":"ThemeColor","kind":"identifier"}],"abstract":[{"type":"text","text":"A color representing all possible variations where this color is used."}],"url":"\/documentation\/theming\/themecolor","role":"symbol","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeColor"},"doc://dev.alexanderweiss.swiftui_theming/documentation/Overview":{"role":"collection","kind":"article","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Overview","abstract":[],"type":"topic","title":"SwiftUI Theming Documentation","url":"\/documentation\/overview"},"doc://dev.alexanderweiss.swiftui_theming/tutorials/MeetSwiftUITheming":{"abstract":[{"type":"text","text":"SwiftUI Theming is a library that enables seamless theming in SwiftUI across all Apple platforms, including iOS, macOS, tvOS, watchOS, and visionOS."}],"kind":"overview","url":"\/tutorials\/meetswiftuitheming","type":"topic","title":"Meet SwiftUI Theming","role":"overview","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/MeetSwiftUITheming"}}}