xt","text":" "},{"type":"text","text":"default provided fonts. They offer predictable, tested and best UI looking results. Per default a newly created "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme","isActive":true},{"type":"text","text":" "},{"type":"text","text":"instance will use Apple’s default font via "},{"type":"codeVoice","code":"\/Theming\/Theme\/FontMap\/appleDefault-property"}],"type":"paragraph"}]}]}],"variants":[{"paths":["\/documentation\/theming\/theme"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/ThemeColor"],"title":"Theming","anchor":"Theming"}],"kind":"symbol","topicSections":[{"generated":true,"identifiers":["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme\/init(name:colors:fonts:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme\/id","doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme\/name"],"title":"Instance Properties","anchor":"Instance-Properties"},{"generated":true,"identifiers":["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme\/ColorMap","doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme\/FontMap"],"title":"Type Aliases","anchor":"Type-Aliases"},{"generated":true,"identifiers":["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme\/Equatable-Implementations","doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme\/Hashable-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"abstract":[{"type":"text","text":"Base type for the theming system describing a single theme."}],"references":{"doc://dev.alexanderweiss.swiftui_theming/s8SendableP":{"identifier":"doc:\/\/dev.alexanderweiss