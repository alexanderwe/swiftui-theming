{"abstract":[{"text":"Base type for the theming system describing a single theme.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Overview"]]},"identifier":{"url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Theme","kind":"identifier"}],"platforms":["iOS","macOS","tvOS","visionOS","watchOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"text","text":"You can create your own themes by creating new instances of this type. When creating your own theme, pay attention to the"},{"text":" ","type":"text"},{"type":"text","text":"different platforms that you support. Especially since not all color variations are availble on all platforms:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ MARK: - Available Themes","extension Theme {","    static let `default`: Theme = .createDefaultTheme()","}","","\/\/ MARK: - Theme creation","extension Theme {","    private static func createDefaultTheme() -> Theme {","        let colors: Theme.ColorMap","","        #if os(iOS) || os(visionOS)","        colors = [","            .primaryLabel: ThemeColor(lightColor: .primary, darkColor: .primary),","            .primaryGroupedBackground: ThemeColor(lightColor: .gray, darkColor: .black),","        ]","        #elseif os(watchOS)","        colors = [","            .primaryLabel: ThemeColor(darkColor: .white, darkHighContrast: .white),","            .primaryGroupedBackground: ThemeColor(darkColor: .black, darkHighContrast: .black),","        ]","        #elseif os(macOS) || os(tvOS)","        colors = [","            .primaryLabel: ThemeColor(lightColor: .primary, darkColor: .primary),","            .primaryGroupedBackground: ThemeColor(lightColor: .gray, darkColor: .black),","        ]","        #endif","        return Theme(name: \"Default\", colors: colors)","    }","}"]},{"name":"Remark","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"While a theme can be used to set custom fonts within the app, the general recommendation is to stick to the Apple"},{"type":"text","text":" "},{"text":"default provided fonts. They offer predictable, tested and best UI looking results. Per default a newly created ","type":"text"},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/documentation\/Theming\/Theme","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"instance will use Apple’s default font via "},{"type":"codeVoice","code":"\/Theming\/Theme\/FontMap\/appleDefault-property"}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/theming\/theme"]}],"kind":"symbol","metadata":{"platforms":[{"introducedAt":"16.0","deprecated":false,"name":"iOS","beta":false,"unavailable":false},{"beta":false,"name":"iPadOS","unavailable":false,"introducedAt":"16.0","deprecated":false},{"introducedAt":"16.0","beta":false,"deprecated":false,"name":"Mac Catalyst","unavailable":false},{"name":"macOS","unavailable":false,"introducedAt":"14.0","deprecated":false,"beta":false},{"name":"tvOS","introducedAt":"17.0","unavailable":false,"beta":false,"deprecated":false},{"beta":false,"name":"visionOS","unavailable":false,"introducedAt":"1.0","deprecated":false},{"unavailable":false,"deprecated":false,"name":"watchOS","beta":false,"introducedAt":"10.0"}],"title":"Theme","modules":[{"name":"Theming"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"Theme","kind":"identifier"}],"navigatorTitle":[{"text":"Theme","kind":"identifier"}],"externalID":"s:7Theming5ThemeV","symbolKind":"struct","roleHeading":"Structure","role":"symbol"},"schemaVersion":{"patch":0,