11, relativeTo: .caption2),","            ]","    }","}"],"syntax":"swift"},"01-03-01-image-0001.png":{"alt":"A screenshot of Xcode showing the newly created 'Resources\/Fonts' directory in the file tree. The right panel highlights the 'Copy Bundle Resources' step in the Xcode build phases, which includes the added custom fonts.","variants":[{"traits":["1x","light"],"url":"\/images\/dev.alexanderweiss.swiftui_theming\/01-03-01-image-0001.png"}],"identifier":"01-03-01-image-0001.png","type":"image"},"01-03-02-code-0006.swift":{"fileType":"swift","type":"file","identifier":"01-03-02-code-0006.swift","content":["import SwiftUI","import Theming","","struct ContentView: View {","    \/\/ MARK: - Body","    var body: some View {","        Text(\"Hello World\")","            .themeFont(.largeTitle)","    }","}"],"syntax":"swift","fileName":"ContentView.swift","highlights":[]},"https://developer.apple.com/documentation/swiftui/font/custom(_:size:relativeto:)":{"title":"custom(_:size:relativeTo:)","url":"https:\/\/developer.apple.com\/documentation\/swiftui\/font\/custom(_:size:relativeto:)","identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/font\/custom(_:size:relativeto:)","type":"link","titleInlineContent":[{"type":"text","text":"custom(_:size:relativeTo:)"}]},"doc://dev.alexanderweiss.swiftui_theming/tutorials/SwiftUITheming/01-01-CreatingThemes":{"type":"topic","title":"Create your first theme","role":"project","url":"\/tutorials\/swiftuitheming\/01-01-creatingthemes","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-01-CreatingThemes","abstract":[{"type":"text","text":"Learn how to create and organize themes effectively in your application."}],"kind":"project","estimatedTime":"10min"},"doc://dev.alexanderweiss.swiftui_theming/tutorials/SwiftUITheming/01-01-CreatingThemes#Create-a-theme":{"type":"section","title":"Create a theme","role":"pseudoSymbol","url":"\/tutorials\/swiftuitheming\/01-01-creatingthemes#Create-