 size: 16, relativeTo: .callout),","                .subheadline: Font.custom(\"CustomFont-Regular\", size: 15, relativeTo: .subheadline),","                .footnote: Font.custom(\"CustomFont-Regular\", size: 13, relativeTo: .footnote),","                .caption: Font.custom(\"CustomFont-Regular\", size: 12, relativeTo: .caption),","                .caption2: Font.custom(\"CustomFont-Regular\", size: 11, relativeTo: .caption2),","            ]","    }","}"],"highlights":[{"line":13},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27}]},"doc://dev.alexanderweiss.swiftui_theming/tutorials/swiftui-theming/01-03-OrganizingFonts#Add-Fonts-to-Your-Application":{"kind":"section","url":"\/tutorials\/swiftui-theming\/01-03-organizingfonts#Add-Fonts-to-Your-Application","abstract":[{"type":"text","text":"Learn how to organize fonts for use in a theme."}],"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/swiftui-theming\/01-03-OrganizingFonts#Add-Fonts-to-Your-Application","type":"section","title":"Add Fonts to Your Application","role":"pseudoSymbol"},"01-03-02-image-0002.png":{"type":"image","alt":"An iOS application displaying bold text with a custom font and a theme-defined primary label color. The text color is blue.","variants":[{"traits":["1x","light"],"url":"\/images\/dev.alexanderweiss.swiftui_theming\/01-03-02-image-0002.png"}],"identifier":"01-03-02-image-0002.png"},"01-03-02-image-0001.png":{"type":"image","alt":"An iOS application displaying text with a custom font applied. The text uses Apple's default primary label color, which is black.","variants":[{"url":"\/images\/dev.alexanderweiss.swiftui_theming\/01-03-02-image-0001.png","traits":["1x","light"]}],"identifier":"01-03-02-image-0001.png"},"doc://dev.alexanderweiss.swiftui_theming/tutorials/swiftui-theming/02-01-ChangeThemesAtRuntime#Create-a-view-to-change-the-theme":{"abstr