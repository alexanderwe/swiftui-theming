atedTimeInMinutes":10,"content":[{"inlineContent":[{"text":"Learn how to create and organize themes effectively in your application.","type":"text"}],"type":"paragraph"}]},{"tasks":[{"title":"Create a theme","stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Create a new SwiftUI View file named "},{"type":"codeVoice","code":"Themes.swift"},{"text":". This file will serve as the central location for all the themes used in your app.","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","code":"01-01-01-code-0001.swift","caption":[],"runtimePreview":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each theme requires a name, a color mapping table, and optionally, a font mapping table. While the font mapping table is optional, the name and color mapping table are mandatory."}]}],"code":"01-01-01-code-0001.swift","type":"step","caption":[],"media":null,"runtimePreview":null},{"code":"01-01-01-code-0002.swift","caption":[],"media":null,"type":"step","runtimePreview":null,"content":[{"inlineContent":[{"text":"To gain better control over theme creation, use dedicated methods for each theme. This approach is similar to implementing a factory method.","type":"text"}],"type":"paragraph"}]},{"type":"step","media":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"With the foundational setup complete, proceed to create color mappings. Start by creating a new file named "},{"type":"codeVoice","code":"ThemeColors.swift"},{"type":"text","text":". This file will define all the color styles your app supports, typically derived from your app’s design guidelines. Each color style is uniquely identified by a name."}]}],"caption":[],"code":"01-01-01-code-0003.swift"},{"media":null,"type":"step","caption":[],"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Next, configure the mapping table to link color styles to their corresponding colors."}],"type":"paragraph"}],"code":"01-01-01-code-0004.swift"},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"If your app supports multiple platforms, you may need to create different mappings, as not all color variants are available across every platform. This also allows you to define distinct color sets tailored to each platform."}],"type":"paragraph"}],"caption":[],"media":null,"code":"01-01-01-code-0005.swift","runtimePreview":null},{"caption":[],"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, create a theme instance, give it a meaningful name, and assign the color mapping you have defined."}]}],"type":"step","runtimePreview":null,"code":"01-01-01-code-0006.swift"}],"anchor":"Create-a-theme","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"Take the initial steps to make your app themeable.","type":"text"}]}]}]}],"kind":"tasks"},{"abstract":[{"text":"Learn how to enable theming in your SwiftUI application.","type":"text"}],"action":{"isActive":true,"type":"reference","overridingTitle":"Get started","identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/swiftui-theming\/01-02-EnableTheming","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]},"featuredEyebrow":"Tutorial","kind":"callToAction","title":"Enable Theming"}],"kind":"project","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/swiftui-theming\/01-01-CreatingThemes"},"variants":[{"paths":["\/tutorials\/swiftui-theming\/01-01-creatingthemes"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"category":"SwiftUI Theming","role":"project","title":"Create your first theme","categoryPathComponent":"MeetSwiftUITheming"},"references":{"doc://dev.alexanderweiss.swiftui_theming/tutorials/MeetSwiftUITheming/Advanced":{"kind":"article","url":"\/tutorials\/meetswiftuitheming\/advanced","role":"article","title":