 {","                Label {","                    Picker(\"Theme\", selection: $themeManager.selectedTheme) {","                        Text(\"Default\").tag(Theme.default)","                        Text(\"Custom\").tag(Theme.custom)","                } icon: {","                    Image(systemName: \"paintpalette\")","                }","            }","        }","        .navigationTitle(\"Settings\")","        #if os(iOS) || os(visionOS)","            .navigationBarTitleDisplayMode(.inline)","        #endif","    }","}"],"identifier":"02-01-01-code-0005.swift","highlights":[{"line":13},{"line":14},{"line":15},{"line":16},{"line":17}],"syntax":"swift"},"doc://dev.alexanderweiss.swiftui_theming/tutorials/SwiftUITheming/01-01-CreatingThemes#Create-a-theme":{"kind":"section","role":"pseudoSymbol","title":"Create a theme","type":"section","abstract":[{"text":"Learn how to create and organize themes effectively in your application.","type":"text"}],"identifier":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/01-01-CreatingThemes#Create-a-theme","url":"\/tutorials\/swiftuitheming\/01-01-creatingthemes#Create-a-theme"}}}