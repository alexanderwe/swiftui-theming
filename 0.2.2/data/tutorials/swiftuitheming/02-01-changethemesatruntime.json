time"},"sections":[{"kind":"hero","estimatedTimeInMinutes":15,"chapter":"Advanced","title":"Change themes at runtime","content":[{"type":"paragraph","inlineContent":[{"text":"Learn how to dynamically change themes at runtime.","type":"text"}]}]},{"kind":"tasks","tasks":[{"stepsSection":[{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Create a file named ","type":"text"},{"type":"codeVoice","code":"ThemeChangerView.swift"},{"text":".","type":"text"}]}],"media":null,"code":"02-01-01-code-0001.swift","runtimePreview":null,"type":"step"},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Access the ","type":"text"},{"type":"codeVoice","code":"ThemeManager"},{"text":" instance from the environment.","type":"text"}]}],"media":null,"code":"02-01-01-code-0002.swift","runtimePreview":null,"type":"step"},{"caption":[{"type":"paragraph","inlineContent":[{"text":"This is required because ","type":"text"},{"type":"codeVoice","code":"ThemeManager"},{"text":" is marked as an ","type":"text"},{"type":"codeVoice","code":"@Observable"},{"text":" type.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"In the view’s body, create a binding to the ","type":"text"},{"type":"codeVoice","code":"ThemeManager"},{"text":" instance.","type":"text"}]}],"media":null,"code":"02-01-01-code-0003.swift","runtimePreview":null,"type":"step"},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Next, add the basic structure of the view. In this case, use a simple ","type":"text"},{"type":"codeVoice","code":"Form"},{"text":" containing a single entry for a picker, allowing the user to select a theme.","type":"text"}]}],"media":null,"code":"02-01-01-code-0004.swift","runtimePreview":null,"type":"step"},{"caption":[{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"For this implementation, ensure you have multiple themes defined in your app and their types are accessible to the module where your theme changer view is located.","type":"text"}]}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"Implement the picker as you would any other picker in SwiftUI. Since ","type":"text"},{"type":"codeVoice","code":"Theme"},{"text":" instances conform to ","type":"text"},{"type":"codeVoice","code":"Hashable"},{"text":", they can be directly used in the ","type":"text"},{"type":"codeVoice","code":"tag"},{"text":" modifier. Additionally, use ","type":"text"},{"type":"codeVoice","code":"@Bindable"},{"text":" to link the picker’s selection directly to the ","type":"text"},{"type":"codeVoice","code":"selectedTheme"},{"text":" property of the ","type":"text"},{"type":"codeVoice","code":"ThemeManager"},{"text":" instance.","type":"text"}]}],"media":null,"code":"02-01-01-code-0005.swift","runtimePreview":null,"type":"step"},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"This implementation provides users with an interface to change themes at runtime. Feel free to enhance it further and create a more visually appealing theme picker using the techniques outlined here.","type":"text"}]}],"media":"02-01-01-video-0001-swiftui-theming-demo.mp4","code":null,"runtimePreview":null,"type":"step"}],"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Before enabling theme changes at runtime, you need a mechanism to trigger the change. This tutorial assumes the change is user-driven through a UI. However, themes can also be changed programmatically without a UI.","type":"text"}]}],"kind":"fullWidth"}],"title":"Create a view to change the theme","anchor":"Create-a-view-to-change-the-theme"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/swiftuitheming\/02-01-changethemesatruntime"]}],"identifier":{"url":"doc:\/\/dev.alexanderweiss.swiftui_theming\/tutorials\/SwiftUITheming\/02-01-ChangeThemesAtRuntime","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":